{
  "name": "@yema/server",
  "version": "0.1.0",
  "description": "yema-server - NestJS backend for the Yema platform",
  "private": true,
  "type": "module",
  "scripts": {
    "start:dev": "concurrently \"npm run build:watch\" \"npm run serve:watch\"",
    "build:watch": "nest build --watch",
    "serve:watch": "nodemon --watch dist/apps/server/src --ext js --delay 1 --exec \"node dist/apps/server/src/main.js\"",
    "build": "nest build",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-fastify": "^11.0.1",
    "@prisma/client": "^6.16.3",
    "@yema/shared": "*",
    "bullmq": "^5.71.1",
    "eslint": "^10.1.0",
    "ioredis": "^5.10.1",
    "parse5": "^8.0.0",
    "playwright": "^1.58.2",
    "prisma": "^6.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/node": "^22.10.1",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "typescript": "^5.7.2"
  }
}

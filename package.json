{
  "name": "yema",
  "version": "0.1.0",
  "description": "yema - LLM-powered frontend online judge",
  "private": true,
  "packageManager": "pnpm@10.18.1",
  "repository": {
    "type": "git",
    "url": "git@github.com:want2sleeep/yema.git"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"pnpm run dev:server\" \"pnpm run dev:web\"",
    "dev:web": "pnpm --filter @yema/web dev",
    "dev:server": "pnpm --filter @yema/server start:dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
